# --- model weights: never in git -------------------------------------------
# Model weights never belong in version control. (The cancelled Qwen3-0.6B
# stage was removed 2026-07-19 — it is a public, re-downloadable base model.)
*.safetensors
*.gguf
*.bin
*.pt
*.pth

# --- legacy pre-v2 tree (v2 is the canonical tree) --------------------------
# The pre-v2 layout is LEGACY and not needed for release. It is KEPT ON DISK
# (archive/ is the F-001..F-065 evidence/proof base per CLAUDE.md) but is NOT
# tracked: it is ~139k files, several under all-rights-reserved third-party
# licences (corpus). Track v2/ as the project; keep the proof base off git.
/archive/

# --- the collected corpus ---------------------------------------------------
# 2.2 GB / 139k files of third-party documentation and code, several under
# all-rights-reserved licences (NVIDIA docs, AMD ISA PDFs, rcon slides).
# It is REPRODUCIBLE: every source is pinned by commit in corpus/*/SOURCES.md
# and re-fetchable with corpus/_tools/. Track the provenance and the tools,
# not the payload.
corpus/*
!corpus/README.md
!corpus/REPORT.md
!corpus/_manifest.json
!corpus/_stats.json
!corpus/_tools/
!corpus/*/
corpus/*/*
!corpus/*/SOURCES.md

# --- delivery snapshots -----------------------------------------------------
# Frozen zips. Stale by design (archive/README.md: never unzip over the tree).
*.zip

# --- python -----------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
build/
dist/

# --- scratch ----------------------------------------------------------------
_manual*.txt
_m_a.txt
_m_b.txt
*.tmp
/CHANGES.md

appsec-corpus/

